                    {isPresent()
                        ? `${type.charAt(0).toUpperCase() + type.slice(1)} Weaknesses`
                        : `No ${type} Weaknesses`}
                </Button>
            </AccordionSummary>
            <AccordionDetails>
                {isPresent() && (
                    <div
                        className="overflow-x-auto overflow-y-auto max-h-64 
                        [&::-webkit-scrollbar]:w-2 
                        [&::-webkit-scrollbar]:h-2
                        [&::-webkit-scrollbar-thumb]:bg-orange-400 
