const ResultTestBlur = ({ size, setSize, isLeftEye, setIsLeftEye, setCountFalse }) => {
    const handleButton = () => {
        if (!isLeftEye) {
            setCountFalse(0)
            setIsLeftEye(!isLeftEye)
            setSize(14.6)
        } else {
            // window.history.pushState({}, '', `/blur/improve/${size}_1_right`);
            window.location.href = `/blur/improve/${size}_1_right`;
